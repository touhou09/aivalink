# AivaLink Environment Variables

# PostgreSQL
POSTGRES_USER=aivalink
POSTGRES_PASSWORD=aivalink_secret
POSTGRES_DB=aivalink

# JWT (shared between FastAPI and Gateway)
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# LLM API Keys
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama (local LLM)
OLLAMA_HOST=http://host.docker.internal:11434

# AI Service
AI_SERVICE_URL=http://localhost:8000

# Gateway
GATEWAY_PORT=3000
GATEWAY_CHAT_MODE=orchestrator

# Redis
REDIS_URL=redis://localhost:6379
